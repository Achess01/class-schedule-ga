model Course {
  courseCode      Int    @id
  name            String
  semester        Int?
  isCommonArea    Boolean @default(false) @map("is_common_area")
  isMandatory     Boolean
  hasLab          Boolean
  numberOfPeriods Int
  typeOfSchedule  String

  configCourses ConfigCourse[]
  courseCareers CourseCareer[]

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  active    Boolean  @default(true)
}
