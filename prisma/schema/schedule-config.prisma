model ScheduleConfig {
  scheduleConfigId BigInt @id @default(autoincrement())
  periodDurationM  Int

  morningStartTime   DateTime
  morningEndTime     DateTime
  afternoonStartTime DateTime
  afternoonEndTime   DateTime

  maxGeneration         Int?
  startPopulationSize   Int?

  selectionMethod Int
  crossMethod     Int
  mutationMethod  Int

  configCourses    ConfigCourse[]
  configProfessors ConfigProfessor[]
  configClassrooms ConfigClassroom[]
  generatedSchedules GeneratedSchedule[]

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  active    Boolean  @default(true)
}
