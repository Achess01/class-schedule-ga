model ConfigCourse {
  configCourseId    BigInt @id @default(autoincrement())
  scheduleConfigId  BigInt
  courseCode        Int
  sectionQty        Int
  scheduleTime      DateTime
  requireClassroom  Boolean
  typeOfSchedule    String
  isFixed           Boolean @default(false)
  fixedDayIndex     Int?
  fixedStartSlot    Int?
  configClassroomId BigInt?

  scheduleConfig ScheduleConfig @relation(fields: [scheduleConfigId], references: [scheduleConfigId])
  course         Course         @relation(fields: [courseCode], references: [courseCode])

  courseProfessors ConfigCourseProfessor[]
  generatedScheduleItems GeneratedScheduleItem[]

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  active    Boolean  @default(true)
}
