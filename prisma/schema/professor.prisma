model Professor {
  professorCode  Int    @id
  firstName      String
  secondName     String?
  lastName       String
  secondLastName String?
  entryTime      DateTime
  exitTime       DateTime

  configProfessors ConfigProfessor[]

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  active    Boolean  @default(true)
}
