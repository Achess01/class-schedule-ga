model Classroom {
  classroomId Int @id @default(autoincrement())
  name        String
  capacity    Int
  typeOfSchedule        String
  classTypeId Int

  configClassrooms ConfigClassroom[]

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  active    Boolean  @default(true)
}
