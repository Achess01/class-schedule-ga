model ConfigProfessor {
  configProfessorId BigInt @id
  professorCode     Int
  scheduleConfigId  BigInt

  professor      Professor      @relation(fields: [professorCode], references: [professorCode])
  scheduleConfig ScheduleConfig @relation(fields: [scheduleConfigId], references: [scheduleConfigId])

  courseProfessors ConfigCourseProfessor[]
  generatedScheduleItems GeneratedScheduleItem[]

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?
  active    Boolean  @default(true)
}
